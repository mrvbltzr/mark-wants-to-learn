{
    "compilerOptions": {
        "target": "es2016",
        "module": "es6",
        "rootDir": "./src",
        "moduleResolution": "node10",
        "removeComments": true,
        "noEmitOnError": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    }
}
